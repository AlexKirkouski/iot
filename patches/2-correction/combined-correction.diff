+///// РЕЖИМЫ ШУМА ПО ВРЕМЕНИ СУТОК /////
+// Режим шума — справочник: название + окно времени + ЦЕЛЬ (граница/середина) + ШУМ.
+// Вешается на датчик; в окне режима корректировка тянет к цели режима с его шумом.
+// Режим не выбран / вне окна -> обычное поведение: к границе, шум организации.
+CLASS CorrectionTarget {
+    toLimit 'К границе',
+    toMiddle 'К середине'
+}
+CLASS NoiseMode 'Режим шума';
+organization 'Организация' = DATA Organization (NoiseMode);
+name 'Название' = DATA STRING[100] (NoiseMode) NONULL IN id;
+timeFrom 'Начало' = DATA TIME (NoiseMode) NONULL;
+timeTo 'Окончание' = DATA TIME (NoiseMode) NONULL;
+target = DATA CorrectionTarget (NoiseMode);
+nameTarget 'Цель' (NoiseMode m) = staticCaption(target(m)) CHARWIDTH 12;
+noise 'Шум (0..1)' = DATA DOUBLE (NoiseMode);
+CONSTRAINT NoiseMode m IS NoiseMode AND timeFrom(m) > timeTo(m)
+    MESSAGE 'Начало режима шума должно быть не позже окончания';
+// По умолчанию при создании: цель — к границе, шум — как у организации
+WHEN SET(NoiseMode m IS NoiseMode) AND NOT target(m) DO target(m) <- CorrectionTarget.toLimit;
+WHEN SET(NoiseMode m IS NoiseMode) AND NOT noise(m) DO noise(m) <- noise(organization(m));
+
+// Выбор режима шума на датчике (по умолчанию не выбран -> обычное поведение)
+noiseMode 'Режим шума' = DATA NoiseMode (Device);
+nameNoiseMode 'Режим шума' (Device d) = name(noiseMode(d)) CHARWIDTH 15;
+CONSTRAINT noiseMode(Device d) AND organization(noiseMode(d)) != organization(d)
+    MESSAGE 'Режим шума должен принадлежать организации датчика';
+
+// Активный режим датчика в момент zdt (если окно покрывает время)
+activeNoiseMode (Device d, ZDATETIME zdt) =
+    noiseMode(d) IF TIME(zdt) >= timeFrom(noiseMode(d)) AND TIME(zdt) <= timeTo(noiseMode(d));
+// Цель корректировки: цель активного режима, иначе — к границе (обычное поведение)
+correctionTarget (Device d, ZDATETIME zdt) = OVERRIDE target(activeNoiseMode(d, zdt)), CorrectionTarget.toLimit;
+// Шум по времени: шум активного режима, иначе — обычный шум организации
+noise (Device d, MeasurementType mt, ZDATETIME zdt) = OVERRIDE noise(activeNoiseMode(d, zdt)), noise(d, mt);
+// Время-зависимый разброс; НЕ MATERIALIZED
+noiseValue (Device d, MeasurementType mt, ZDATETIME zdt) = (maxAdjFixedValue(d, mt) - minAdjFixedValue(d, mt)) * noise(d, mt, zdt);
+// Середина диапазона и цели: к границе минус шум, либо к середине (по цели режима)
+midAdjValue (Device d, MeasurementType mt) = (minAdjFixedValue(d, mt) + maxAdjFixedValue(d, mt)) / 2;
+upperTarget (Device d, MeasurementType mt, ZDATETIME zdt) =
+    IF correctionTarget(d, zdt) = CorrectionTarget.toMiddle THEN midAdjValue(d, mt) ELSE maxAdjFixedValue(d, mt) - noiseValue(d, mt, zdt);
+lowerTarget (Device d, MeasurementType mt, ZDATETIME zdt) =
+    IF correctionTarget(d, zdt) = CorrectionTarget.toMiddle THEN midAdjValue(d, mt) ELSE minAdjFixedValue(d, mt) + noiseValue(d, mt, zdt);
+
 timeFrom(Device d, ZDATETIME zdt) = timeFrom(location(d), DATE(zdt));
 timeTo(Device d, ZDATETIME zdt) = timeTo(location(d), DATE(zdt));
-adjustTimeFrom(Device d, MeasurementType mt, ZDATETIME zdt) = sumMinutes(timeFrom(d, zdt), -periodMinutes(d, mt)); 
