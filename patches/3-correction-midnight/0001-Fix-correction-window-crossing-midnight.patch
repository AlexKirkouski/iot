From a1c5f54b5cd22a1f75a69322114aa9dc22d0fd30 Mon Sep 17 00:00:00 2001
From: Mia Gorceva <elena@mite.club>
Date: Sun, 7 Jun 2026 13:24:12 +0300
Subject: [PATCH] Fix correction window crossing midnight

Control 'from-to' now works at any time of day, including windows that
cross 00:00 (e.g. 22:00-06:00) for machines on multi-day trips. No flags:
if a from-to window is configured, it is honoured regardless of time of day.

- inAdjustWindow: when start > end, treat the window as [start..24]+[00..end]
- elapsedFromStart: add a day after midnight so the decay anchor stays correct
- isAdjustActive: use inAdjustWindow instead of raw time comparisons

Previously such windows produced an empty/broken interval and the correction
fell into an error.

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
---
 src/main/lsfusion/Mite.lsf | 21 ++++++++++++++-------
 1 file changed, 14 insertions(+), 7 deletions(-)

diff --git a/src/main/lsfusion/Mite.lsf b/src/main/lsfusion/Mite.lsf
index 85bd6f2..537b32a 100644
--- a/src/main/lsfusion/Mite.lsf
+++ b/src/main/lsfusion/Mite.lsf
@@ -185,6 +185,15 @@ timeFrom(Device d, ZDATETIME zdt) = timeFrom(location(d), DATE(zdt));
 timeTo(Device d, ZDATETIME zdt) = timeTo(location(d), DATE(zdt));
 adjustTimeFrom(Device d, MeasurementType mt, ZDATETIME zdt) = sumMinutes(timeFrom(d, zdt), -periodMinutes(d, mt));
 adjustTimeTo(Device d, MeasurementType mt, ZDATETIME zdt) = sumMinutes(timeTo(d,zdt), periodMinutes(d, mt));
+// Окно активности с учётом перехода через полночь: если начало > конец, окно «через 00:00» (контролируем [начало..24] И [00..конец])
+inAdjustWindow(Device d, MeasurementType mt, ZDATETIME zdt) =
+    IF adjustTimeFrom(d, mt, zdt) <= adjustTimeTo(d, mt, zdt)
+        THEN TIME(zdt) >= adjustTimeFrom(d, mt, zdt) AND TIME(zdt) <= adjustTimeTo(d, mt, zdt)
+        ELSE TIME(zdt) >= adjustTimeFrom(d, mt, zdt) OR TIME(zdt) <= adjustTimeTo(d, mt, zdt);
+// Секунды с начала окна с учётом перехода через полночь (после 00:00 добавляем сутки)
+elapsedFromStart(Device d, MeasurementType mt, ZDATETIME zdt) =
+    IF TIME(zdt) >= timeFrom(d, zdt) THEN subtractSeconds(TIME(zdt), timeFrom(d, zdt))
+        ELSE subtractSeconds(TIME(zdt), timeFrom(d, zdt)) + 86400;
 
 adjust(Device d, MeasurementType mt, DOUBLE prevValueToTarget, INTEGER secondsToTarget, ZDATETIME zdt) =
     IF secondsToTarget <= measurementPeriod(d) OR abs(prevValueToTarget) <= noiseValue(d, mt, zdt) THEN 0.0
@@ -193,10 +202,10 @@ adjustTargetValue(DOUBLE target, Device d, MeasurementType mt, INTEGER secondsTo
 
 // Вспомогательный clamp: при выходе за границу тянем к цели (граница или середина — по режиму датчика). Шум — по времени.
 adjustTargetValue(Device d, MeasurementType mt, ZDATETIME zdt, DOUBLE v) =
-        IF TIME(zdt) >= adjustTimeFrom(d, mt, zdt) AND TIME(zdt) <= adjustTimeTo(d, mt, zdt) AND v IS DOUBLE THEN
-            CASE WHEN TIME(zdt) > timeTo(location(d), DATE(zdt)) THEN adjustTargetValue(v, d, mt, subtractSeconds(TIME(zdt), adjustTimeTo(d, mt, zdt)), zdt) // we're coming back
-                 WHEN v > maxAdjFixedValue(d, mt) THEN min(adjustTargetValue(upperTarget(d, mt, zdt), d, mt, subtractSeconds(TIME(zdt), timeFrom(d, zdt)), zdt), v)
-                 WHEN v < minAdjFixedValue(d, mt) THEN max(adjustTargetValue(lowerTarget(d, mt, zdt), d, mt, subtractSeconds(TIME(zdt), timeFrom(d, zdt)), zdt), v)
+        IF inAdjustWindow(d, mt, zdt) AND v IS DOUBLE THEN
+            CASE WHEN adjustTimeFrom(d, mt, zdt) <= adjustTimeTo(d, mt, zdt) AND TIME(zdt) > timeTo(location(d), DATE(zdt)) THEN adjustTargetValue(v, d, mt, subtractSeconds(TIME(zdt), adjustTimeTo(d, mt, zdt)), zdt) // we're coming back (только для окна в пределах суток)
+                 WHEN v > maxAdjFixedValue(d, mt) THEN min(adjustTargetValue(upperTarget(d, mt, zdt), d, mt, elapsedFromStart(d, mt, zdt), zdt), v)
+                 WHEN v < minAdjFixedValue(d, mt) THEN max(adjustTargetValue(lowerTarget(d, mt, zdt), d, mt, elapsedFromStart(d, mt, zdt), zdt), v)
                  ELSE v;
 
 // Применяем зажатие по расписанию во время финальной корректировки измерений
@@ -285,9 +294,7 @@ DESIGN locations {
 ///// КОРРЕКТИРОВКА ЗАДНИМ ЧИСЛОМ /////
 
 isAdjustActive 'Корр. активна' (Device d, MeasurementType mt) =
-    adjustConfigured(d, mt) AND
-            TIME(currentZDateTime()) >= adjustTimeFrom(d, mt, currentZDateTime()) AND
-            TIME(currentZDateTime()) <= adjustTimeTo(d, mt, currentZDateTime());
+    adjustConfigured(d, mt) AND inAdjustWindow(d, mt, currentZDateTime());
 
 retroDateFrom 'Период с' = DATA LOCAL ZDATETIME ();
 retroDateTo 'Период по' = DATA LOCAL ZDATETIME ();
