+// Секунды с начала окна с учётом перехода через полночь (после 00:00 добавляем сутки)
+elapsedFromStart(Device d, MeasurementType mt, ZDATETIME zdt) =
+    IF TIME(zdt) >= timeFrom(d, zdt) THEN subtractSeconds(TIME(zdt), timeFrom(d, zdt))
+        ELSE subtractSeconds(TIME(zdt), timeFrom(d, zdt)) + 86400;
 
