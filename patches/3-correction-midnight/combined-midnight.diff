 adjustTimeTo(Device d, MeasurementType mt, ZDATETIME zdt) = sumMinutes(timeTo(d,zdt), periodMinutes(d, mt));
+// Окно активности с учётом перехода через полночь: если начало > конец, окно «через 00:00» (контролируем [начало..24] И [00..конец])
+inAdjustWindow(Device d, MeasurementType mt, ZDATETIME zdt) =
+    IF adjustTimeFrom(d, mt, zdt) <= adjustTimeTo(d, mt, zdt)
+        THEN TIME(zdt) >= adjustTimeFrom(d, mt, zdt) AND TIME(zdt) <= adjustTimeTo(d, mt, zdt)
