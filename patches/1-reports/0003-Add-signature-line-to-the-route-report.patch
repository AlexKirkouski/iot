Content-Transfer-Encoding: 8bit

The production route report carries a signature line at the bottom (as the limit
report does), but the repo's Mite_routeReport.jrxml had no footer/summary band.
Add pPosition/pFio parameters (defaults "Должность"/"ФИО") and a summary band
rendering "<Должность>, <ФИО>, подпись", mirroring Mite_limitReport.jrxml.

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
---
 .../lsfusion/reports/Mite_routeReport.jrxml   | 20 +++++++++++++++++++
 1 file changed, 20 insertions(+)

diff --git a/src/main/lsfusion/reports/Mite_routeReport.jrxml b/src/main/lsfusion/reports/Mite_routeReport.jrxml
index 3d72c57..d3458f9 100644
--- a/src/main/lsfusion/reports/Mite_routeReport.jrxml
+++ b/src/main/lsfusion/reports/Mite_routeReport.jrxml
@@ -36,6 +36,12 @@
 	<parameter name="pFormCode" class="java.lang.String">
 		<defaultValueExpression><![CDATA["Ф/08-СОП № 11-С"]]></defaultValueExpression>
 	</parameter>
+	<parameter name="pPosition" class="java.lang.String">
+		<defaultValueExpression><![CDATA["Должность"]]></defaultValueExpression>
+	</parameter>
+	<parameter name="pFio" class="java.lang.String">
+		<defaultValueExpression><![CDATA["ФИО"]]></defaultValueExpression>
+	</parameter>
 	<field name="d.object" class="java.time.LocalDate"/>
 	<field name="o.object" class="java.lang.Long"/>
 	<field name="mt.object" class="java.lang.Long"/>
@@ -197,4 +203,18 @@
 			</textField>
 		</band>
 	</detail>
+	<summary>
+		<band height="34">
+			<textField>
+				<reportElement x="26" y="14" width="600" height="16" uuid="b9d7e2a1-5c4f-4a3b-9e21-7d6c8f0a1b23"/>
+				<textElement textAlignment="Left" verticalAlignment="Middle">
+					<font fontName="DejaVu Serif" size="12"/>
+				</textElement>
+				<textFieldExpression><![CDATA[($P{pPosition} == null ? "Должность" : $P{pPosition})
++ ", " +
+($P{pFio} == null ? "ФИО" : $P{pFio})
++ ", подпись"]]></textFieldExpression>
+			</textField>
+		</band>
+	</summary>
 </jasperReport>
