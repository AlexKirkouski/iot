diff --git a/src/main/lsfusion/Mite.lsf b/src/main/lsfusion/Mite.lsf
index 147bb3e..2752a4a 100644
--- a/src/main/lsfusion/Mite.lsf
+++ b/src/main/lsfusion/Mite.lsf
@@ -514,7 +514,7 @@ reportTime 'Время отчета' = DATA TIME (Organization);
 routeReportDevice(Device d, MeasurementType mt) = machineLocation(d) AND number(type(d), mt) AND minReportFixedValue(d, mt) AND maxReportFixedValue(d, mt);
 hasRouteReportDevice(Location l, MeasurementType mt) = GROUP MAX routeReportDevice(Device d, mt) AND machineLocation(d) = l;
 routeReportInterval 'Интервал' (Device d, MeasurementType mt) =
-    'От ' + round0(minReportFixedValue(d, mt)) + ' до ' + round0(maxReportFixedValue(d, mt)) IF routeReportDevice(d, mt) MATERIALIZED;
+    r'От ' + round0(minReportFixedValue(d, mt)) + r' до ' + round0(maxReportFixedValue(d, mt)) IF routeReportDevice(d, mt) MATERIALIZED;
 routeReportIntervalValue 'Интервал' (STRING interval) = interval IF interval IS STRING;
 hasRouteReportInterval(Organization o, MeasurementType mt, STRING interval) =
     GROUP MAX routeReportDevice(Device d, mt) AND organization(d) = o AND routeReportInterval(d, mt) = interval;
@@ -531,12 +531,15 @@ routeReportFactMinValue 'Мин. реальное значение' (Location l,
 routeReportFactMaxValue 'Макс. реальное значение' (Location l, STRING interval, MeasurementType mt, DATE d) =
     GROUP MAX value(Measurement m, mt) IF inRouteReportPeriod(m, mt, l, d) AND routeReportInterval(device(m, mt), mt) = interval;
 routeReportFactInterval 'Фактический интервал' (Location l, STRING interval, MeasurementType mt, DATE d) =
-    'От ' + round0(routeReportFactMinValue(l, interval, mt, d)) + ' до ' + round0(routeReportFactMaxValue(l, interval, mt, d));
+    r'От ' + round0(routeReportFactMinValue(l, interval, mt, d)) + r' до ' + round0(routeReportFactMaxValue(l, interval, mt, d));
 
 EXTEND FORM locations
     PROPERTIES routeTimeFrom(l, ds), routeTimeTo(l, ds)
 ;
 
+reportControl 'Контроль' (Device dev, MeasurementType mt, ZDATETIME zdt) =
+    value(dev, mt, zdt) >= minReportFixedValue(dev, mt) AND value(dev, mt, zdt) <= maxReportFixedValue(dev, mt);
+
 FORM limitReport 'Отчет по значениям до корректировки'
     OBJECTS d = DATE PANEL, o = Organization PANEL
     PROPERTIES(d) date = VALUE
@@ -547,6 +550,7 @@ FORM limitReport 'Отчет по значениям до корректиров
     PROPERTIES(mt) mtName = name
     PROPERTIES val = value(dev, mt, ZDATETIME(toDateTime(d, reportTime(o)))), dateTime = ZDATETIME(toDateTime(d, reportTime(o))), time = reportTime(o)
     PROPERTIES minReportFixedValue(dev, mt), maxReportFixedValue(dev, mt)
+    PROPERTIES control = reportControl(dev, mt, ZDATETIME(toDateTime(d, reportTime(o))))
     ORDERS container(dev)
     FILTERS organization(dev) == o, container(dev),
             minReportFixedValue(dev, mt) AND maxReportFixedValue(dev, mt)
@@ -581,6 +585,10 @@ FORM routeReportDialog 'Параметры отчета по маршрутам'
     PROPERTIES(mt) name SELECTOR
 ;
 
+routeControl 'Контроль' (Location ml, MeasurementType mt, DATE d) =
+    NOT (GROUP SUM 1 IF inRouteReportPeriod(Measurement m, mt, ml, d) AND
+            (value(m, mt) < minReportFixedValue(device(m, mt), mt) OR value(m, mt) > maxReportFixedValue(device(m, mt), mt)));
+
 FORM routeReport 'Отчет контроля маршрутов'
     OBJECTS d = DATE PANEL, o = Organization PANEL, mt = MeasurementType PANEL
 
@@ -591,6 +599,7 @@ FORM routeReport 'Отчет контроля маршрутов'
     PROPERTIES machineName = name(ml)
     PROPERTIES routeTimeFrom = routeTimeFrom(ml, d), routeTimeTo = routeTimeTo(ml, d)
     PROPERTIES factInterval = routeReportFactInterval(ml, interval, mt, d) COLUMNS (interval) HEADER routeReportIntervalValue(interval)
+    PROPERTIES control = routeControl(ml, mt, d)
     FILTERS organization(ml) == o, machine(ml), hasRouteReportDevice(ml, mt), routeTimeFrom(ml, d), routeTimeTo(ml, d)
     ORDERS machineName
 ;
